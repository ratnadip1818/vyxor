{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-weekly?region=india",
      "schedule": "30 3 * * 0"
    },
    {
      "path": "/api/cron-weekly?region=london",
      "schedule": "0 8 * * 0"
    },
    {
      "path": "/api/cron-weekly?region=newyork",
      "schedule": "0 14 * * 0"
    }
  ]
}
